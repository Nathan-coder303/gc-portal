generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Company {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  projects  Project[]
  users     User[]
  partners  Partner[]
}

model Project {
  id             String         @id @default(cuid())
  companyId      String
  company        Company        @relation(fields: [companyId], references: [id])
  name           String
  code           String
  startDate      DateTime
  budget         Decimal        @db.Decimal(14, 2)
  status         String         @default("ACTIVE")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  expenses       Expense[]
  costCodes      CostCode[]
  tasks          Task[]
  accounts       Account[]
  journalEntries JournalEntry[]
}

model User {
  id           String   @id @default(cuid())
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id])
  email        String   @unique
  name         String
  role         Role     @default(PM)
  passwordHash String
  createdAt    DateTime @default(now())
}

enum Role {
  ADMIN
  PM
  BOOKKEEPER
  PARTNER
}

model CostCode {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id])
  code         String
  name         String
  budgetAmount Decimal   @default(0) @db.Decimal(14, 2)
  expenses     Expense[]

  @@unique([projectId, code])
}

model Expense {
  id            String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id])
  companyId     String
  date          DateTime  @db.Date
  vendor        String
  description   String
  costCodeId    String?
  costCode      CostCode? @relation(fields: [costCodeId], references: [id])
  category      String
  amount        Decimal   @db.Decimal(14, 2)
  tax           Decimal   @default(0) @db.Decimal(14, 2)
  paymentMethod String
  paidBy        String
  receiptUrl    String?
  isDuplicate   Boolean   @default(false)
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Task {
  id              String     @id @default(cuid())
  projectId       String
  project         Project    @relation(fields: [projectId], references: [id])
  phase           String
  name            String
  durationDays    Int
  startDate       DateTime?  @db.Date
  endDate         DateTime?  @db.Date
  predecessorIds  String[]
  trade           String?
  assignee        String?
  isMilestone     Boolean    @default(false)
  status          TaskStatus @default(NOT_STARTED)
  percentComplete Int        @default(0)
  notes           String?
  createdBy       String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  DONE
}

model Account {
  id               String        @id @default(cuid())
  projectId        String
  project          Project       @relation(fields: [projectId], references: [id])
  name             String
  type             AccountType
  isPartnerCapital Boolean       @default(false)
  lines            JournalLine[]
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  EXPENSE
  REVENUE
}

model Partner {
  id        String        @id @default(cuid())
  companyId String
  company   Company       @relation(fields: [companyId], references: [id])
  name      String
  email     String?
  lines     JournalLine[]
}

model JournalEntry {
  id        String        @id @default(cuid())
  projectId String
  project   Project       @relation(fields: [projectId], references: [id])
  date      DateTime      @db.Date
  memo      String
  reference String?
  createdBy String
  createdAt DateTime      @default(now())
  lines     JournalLine[]
}

model JournalLine {
  id        String       @id @default(cuid())
  entryId   String
  entry     JournalEntry @relation(fields: [entryId], references: [id])
  accountId String
  account   Account      @relation(fields: [accountId], references: [id])
  partnerId String?
  partner   Partner?     @relation(fields: [partnerId], references: [id])
  debit     Decimal      @default(0) @db.Decimal(14, 2)
  credit    Decimal      @default(0) @db.Decimal(14, 2)
}
