generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  PM
  BOOKKEEPER
  PARTNER
}

enum TaskStatus {
  NOT_STARTED
  IN_PROGRESS
  BLOCKED
  DONE
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  EXPENSE
  REVENUE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  ARCHIVE
  RESTORE
  IMPORT
  REVERSE
}

enum EntityType {
  EXPENSE
  COST_CODE
  TASK
  JOURNAL_ENTRY
  PARTNER
  ACCOUNT
  USER
  PROJECT
  PROJECT_SETTINGS
}

// ─── Core ────────────────────────────────────────────────────────────────────

model Company {
  id        String    @id @default(cuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  projects  Project[]
  users     User[]
  partners  Partner[]
}

model Project {
  id             String           @id @default(cuid())
  companyId      String
  company        Company          @relation(fields: [companyId], references: [id])
  name           String
  code           String
  startDate      DateTime
  budget         Decimal          @db.Decimal(14, 2)
  status         String           @default("ACTIVE")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  updatedBy      String?
  expenses       Expense[]
  costCodes      CostCode[]
  tasks          Task[]
  accounts       Account[]
  journalEntries JournalEntry[]
  auditLogs      AuditLog[]
  settings       ProjectSettings[]
}

model User {
  id           String    @id @default(cuid())
  companyId    String
  company      Company   @relation(fields: [companyId], references: [id])
  email        String    @unique
  name         String
  role         Role      @default(PM)
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  updatedBy    String?
  archivedAt   DateTime?
  archivedBy   String?
}

// ─── Expenses ────────────────────────────────────────────────────────────────

model CostCode {
  id           String    @id @default(cuid())
  projectId    String
  project      Project   @relation(fields: [projectId], references: [id])
  code         String
  name         String
  budgetAmount Decimal   @default(0) @db.Decimal(14, 2)
  expenses     Expense[]
  updatedAt    DateTime  @updatedAt
  updatedBy    String?
  archivedAt   DateTime?
  archivedBy   String?

  @@unique([projectId, code])
}

model Expense {
  id            String    @id @default(cuid())
  projectId     String
  project       Project   @relation(fields: [projectId], references: [id])
  companyId     String
  date          DateTime  @db.Date
  vendor        String
  description   String
  costCodeId    String?
  costCode      CostCode? @relation(fields: [costCodeId], references: [id])
  category      String
  amount        Decimal   @db.Decimal(14, 2)
  tax           Decimal   @default(0) @db.Decimal(14, 2)
  paymentMethod String
  paidBy        String
  receiptUrl    String?
  receiptHash   String?
  notes         String?
  isPossibleDup Boolean   @default(false)
  isDuplicate   Boolean   @default(false)
  createdBy     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  updatedBy     String?
  archivedAt    DateTime?
  archivedBy    String?
}

// ─── Schedule ─────────────────────────────────────────────────────────────────

model Task {
  id              String          @id @default(cuid())
  projectId       String
  project         Project         @relation(fields: [projectId], references: [id])
  phase           String
  name            String
  durationDays    Int
  startDate       DateTime?       @db.Date
  endDate         DateTime?       @db.Date
  predecessorIds  String[]
  trade           String?
  assignee        String?
  isMilestone     Boolean         @default(false)
  status          TaskStatus      @default(NOT_STARTED)
  percentComplete Int             @default(0)
  notes           String?
  createdBy       String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  updatedBy       String?
  archivedAt      DateTime?
  archivedBy      String?
  changeLogs      TaskChangeLog[]
}

model TaskChangeLog {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id])
  field     String
  oldValue  String?
  newValue  String?
  changedBy String
  changedAt DateTime @default(now())
}

// ─── Ledger ──────────────────────────────────────────────────────────────────

model Account {
  id               String        @id @default(cuid())
  projectId        String
  project          Project       @relation(fields: [projectId], references: [id])
  name             String
  type             AccountType
  isPartnerCapital Boolean       @default(false)
  updatedBy        String?
  archivedAt       DateTime?
  archivedBy       String?
  lines            JournalLine[]
}

model Partner {
  id           String        @id @default(cuid())
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id])
  name         String
  email        String?
  role         String?
  ownershipPct Decimal?      @db.Decimal(5, 2)
  notes        String?
  updatedAt    DateTime      @updatedAt
  updatedBy    String?
  archivedAt   DateTime?
  archivedBy   String?
  lines        JournalLine[]
}

model JournalEntry {
  id         String        @id @default(cuid())
  projectId  String
  project    Project       @relation(fields: [projectId], references: [id])
  date       DateTime      @db.Date
  memo       String
  reference  String?
  isReversal Boolean       @default(false)
  reversesId String?
  createdBy  String
  createdAt  DateTime      @default(now())
  lines      JournalLine[]
}

model JournalLine {
  id        String       @id @default(cuid())
  entryId   String
  entry     JournalEntry @relation(fields: [entryId], references: [id])
  accountId String
  account   Account      @relation(fields: [accountId], references: [id])
  partnerId String?
  partner   Partner?     @relation(fields: [partnerId], references: [id])
  debit     Decimal      @default(0) @db.Decimal(14, 2)
  credit    Decimal      @default(0) @db.Decimal(14, 2)
}

// ─── Audit & Settings ────────────────────────────────────────────────────────

/// Append-only audit trail. Never updated or deleted.
model AuditLog {
  id         String      @id @default(cuid())
  companyId  String
  projectId  String?
  project    Project?    @relation(fields: [projectId], references: [id])
  entityType EntityType
  entityId   String
  action     AuditAction
  /// JSON array of {field, oldValue, newValue}
  changes    String      @default("[]")
  /// Required for financial/schedule-critical changes
  reason     String?
  userId     String
  userName   String
  createdAt  DateTime    @default(now())

  @@index([projectId, entityType, createdAt])
  @@index([entityId])
  @@index([userId])
}

/// Per-project key-value settings (KPI assumptions, widget config, alert thresholds).
model ProjectSettings {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
  key       String
  value     String
  updatedBy String
  updatedAt DateTime @updatedAt

  @@unique([projectId, key])
}
